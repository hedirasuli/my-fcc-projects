{
  "compilerOptions": {
    "target": "ES6",                          
    "module": "ESNext",                      
    "moduleResolution": "bundler",              
    "outDir": "./dist",                      
    "rootDir": "./",                         
    "strict": true,                          
    "esModuleInterop": true,                 
    "skipLibCheck": true,                    
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": false             
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}